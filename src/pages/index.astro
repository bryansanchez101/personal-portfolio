---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="w-full">
    <!-- Hero section -->
    <section
      class="relative mb-10 w-full overflow-hidden rounded-2xl border border-base-300 bg-gradient-to-br from-[#fff7f7] via-base-100 to-[#fff8df] px-5 py-8 shadow-[0_20px_60px_rgba(153,0,0,0.08)] sm:rounded-3xl sm:px-8 sm:py-10 lg:px-12 lg:py-14"
    >
      <!-- Background glow effects -->
      <div
        class="pointer-events-none absolute -right-20 top-8 h-64 w-64 rounded-full bg-[#FFC72C]/25 blur-3xl sm:h-80 sm:w-80"
      >
      </div>

      <div
        class="pointer-events-none absolute -bottom-24 left-10 h-64 w-64 rounded-full bg-[#990000]/10 blur-3xl"
      >
      </div>

      <!-- Dotted decoration -->
      <div
        class="pointer-events-none absolute right-8 top-8 hidden h-36 w-44 opacity-25 lg:block"
        style="background-image: radial-gradient(#990000 1.5px, transparent 1.5px); background-size: 14px 14px;"
      >
      </div>

      <!-- Hero content -->
      <div
        class="relative z-10 grid w-full grid-cols-1 items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(260px,380px)] lg:gap-14"
      >
        <!-- Intro text -->
        <div class="w-full">
          <p class="mb-3 text-base font-semibold text-[#990000] sm:text-lg">
            Hey there 👋
          </p>

          <h1
            class="text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl xl:text-7xl"
          >
            I'm Bryan
            <span class="block">Sanchez</span>
          </h1>

          <h2
            class="py-5 text-xl font-bold leading-tight text-[#990000] sm:text-2xl lg:text-3xl"
          >
            Aspiring Software Engineer and Entrepreneur
          </h2>

          <p
            class="max-w-3xl text-base leading-relaxed opacity-80 sm:text-lg lg:text-xl"
          >
            I am a rising high school junior with a strong interest in software
            engineering and design. I enjoy challenging myself, learning new
            technologies, and building projects that solve real world problems.
            My goal is to continue growing my technical skills while creating
            meaningful software.
          </p>

          <!-- Buttons -->
          <div class="mt-8 flex w-full flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a
              class="btn w-full border-none bg-[#990000] px-7 text-white shadow-md hover:bg-[#7a0000] sm:w-auto"
              href="https://www.linkedin.com/in/bryan-sanchez-417a48378/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Let's connect! →
            </a>

            <a
              class="btn w-full border-[#d9b44a] bg-base-100/80 px-7 hover:bg-[#fff4cc] sm:w-auto"
              href="/projects"
            >
              View my projects
            </a>
          </div>
        </div>

        <!-- Profile image -->
        <div class="relative mx-auto shrink-0 lg:mx-0 lg:justify-self-end">
          <div
            class="absolute inset-0 scale-110 rounded-full bg-gradient-to-br from-[#990000]/20 to-[#FFC72C]/30 blur-2xl"
          >
          </div>

          <img
            src="/profile.jpg"
            alt="Bryan Sanchez"
            class="relative h-52 w-52 rounded-full border-4 border-white object-cover shadow-xl sm:h-64 sm:w-64 lg:h-80 lg:w-80 xl:h-96 xl:w-96"
            style="object-position: center 22%;"
          />
        </div>
      </div>
    </section>

    <!-- Featured project section -->
    <section class="mb-12 w-full">
      <div
        class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
      >
        <div class="flex items-center gap-3">
          <div
            class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-[#990000]/10 text-[#990000]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>

          <div>
            <p
              class="text-xs font-semibold uppercase tracking-wider opacity-60 sm:text-sm"
            >
              My Work
            </p>

            <h2 class="text-2xl font-bold sm:text-3xl">
              Featured Project
            </h2>
          </div>
        </div>

        <a
          href="/projects"
          class="font-semibold text-[#990000] hover:underline"
        >
          View all projects →
        </a>
      </div>

      <!-- Project card -->
      <article
        class="group w-full overflow-hidden rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:rounded-3xl sm:p-6"
      >
        <div
          class="grid grid-cols-1 gap-6"
        >
          <!-- Project image -->
          <div
            
          >
            <img
        
          
            />
          </div>

          <!-- Project information -->
          <div class="min-w-0 flex-1">
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <h3 class="text-xl font-bold sm:text-2xl lg:text-3xl">
                Liberty for All Medical Translator
              </h3>

              <span
                class="rounded-full bg-[#990000] px-3 py-1 text-xs font-bold text-white"
              >
                FEATURED
              </span>
            </div>

            <p class="text-base leading-relaxed opacity-80 sm:text-lg">
              A medical application designed to help non english speakers
              understand their medical records through real time translation,
              AI assistance, appointment management, and secure record storage.
            </p>

            <!-- Project tags -->
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Figma UI/UX
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                AI
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Healthcare
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Translation
              </span>
            </div>

            <a
              class="btn mt-6 w-full border-none bg-[#990000] text-white hover:bg-[#7a0000] sm:w-auto"
              href="https://canva.link/mdb9zxz78cu0bjv"
              target="_blank"
              rel="noopener noreferrer"
            >
              View Project →
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</BaseLayout>
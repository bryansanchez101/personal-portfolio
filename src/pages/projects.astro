---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="w-full">
    <!-- Projects header -->
    <section
      class="relative mb-10 w-full overflow-hidden rounded-2xl border border-base-300 bg-gradient-to-br from-[#fff7f7] via-base-100 to-[#fff8df] px-5 py-10 shadow-[0_20px_60px_rgba(153,0,0,0.08)] sm:rounded-3xl sm:px-8 lg:px-12 lg:py-14"
    >
      <!-- Red glow -->
      <div
        class="pointer-events-none absolute -bottom-24 left-10 h-64 w-64 rounded-full bg-[#990000]/10 blur-3xl"
      >
      </div>

      <!-- Gold glow -->
      <div
        class="pointer-events-none absolute -right-20 -top-16 h-72 w-72 rounded-full bg-[#FFC72C]/25 blur-3xl"
      >
      </div>

      <!-- Dotted decoration -->
      <div
        class="pointer-events-none absolute right-8 top-8 hidden h-36 w-44 opacity-25 md:block"
        style="background-image: radial-gradient(#990000 1.5px, transparent 1.5px); background-size: 14px 14px;"
      >
      </div>

      <div class="relative z-10 max-w-3xl">
        <p
          class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[#990000] sm:text-base"
        >
          My Work
        </p>

        <h1
          class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl"
        >
          Projects
        </h1>

        <p class="mt-5 text-base leading-relaxed opacity-80 sm:text-lg">
          Explore the software, design, and research projects that have helped
          me develop my technical skills, creativity, teamwork, and ability to
          solve problems.
        </p>
      </div>
    </section>

    <!-- Project section heading -->
    <section class="mb-6">
      <div class="flex items-center gap-3">
        <div
          class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-[#990000]/10 text-[#990000]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </div>

        <div>
          <p
            class="text-xs font-semibold uppercase tracking-wider opacity-60 sm:text-sm"
          >
            Selected Work
          </p>

          <h2 class="text-2xl font-bold sm:text-3xl">
            My Projects
          </h2>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="grid w-full grid-cols-1 gap-7">
      <!-- Liberty for All -->
      <article
        class="group w-full overflow-hidden rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:rounded-3xl sm:p-6"
      >
        <div class="grid w-full grid-cols-1 gap-6">
          <!-- Project information -->
          <div class="min-w-0 w-full">
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <h2 class="text-2xl font-bold sm:text-3xl">
                Liberty for All Medical Translator
              </h2>

              <span
                class="rounded-full bg-[#990000] px-3 py-1 text-xs font-bold text-white"
              >
                FEATURED
              </span>
            </div>

            <p class="mb-4 font-semibold text-[#990000]">
              May 2025 – August 2025 · California
            </p>

            <p class="text-base leading-relaxed opacity-80 sm:text-lg">
              A medical application developed to help non english speakers understand their medical records through real time translation, AI assistance, appointment management, and secure record storage.
            </p>

            <!-- Tags -->
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                canva
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                UI/UX
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                AI
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Healthcare
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Translation
              </span>
            </div>

            <a
              class="btn mt-6 w-full border-none bg-[#990000] px-6 text-white shadow-md hover:bg-[#7a0000] sm:w-auto"
              href="https://canva.link/mdb9zxz78cu0bjv"
              target="_blank"
              rel="noopener noreferrer"
            >
              View canva Project →
            </a>
          </div>
        </div>
      </article>

      <!-- ThinkNeuro -->
      <article
        class="group w-full overflow-hidden rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:rounded-3xl sm:p-6"
      >
        <div
          class="grid grid-cols-1 items-center gap-6 lg:grid-cols-[minmax(260px,34%)_minmax(0,1fr)] lg:gap-9"
        >
          <!-- Research visual -->
          <div
            class="relative flex min-h-56 w-full items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-[#fff7f7] to-[#fff4cc] sm:min-h-64"
          >
            <div
              class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-[#FFC72C]/30 blur-2xl"
            >
            </div>

            <div
              class="absolute -bottom-14 -left-12 h-44 w-44 rounded-full bg-[#990000]/15 blur-2xl"
            >
            </div>

            <div
              class="relative z-10 grid h-32 w-32 place-items-center rounded-full border-4 border-white bg-base-100/70 text-[#990000] shadow-xl"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="72"
                height="72"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9.5 4.5A3.5 3.5 0 0 0 6 8v1a3 3 0 0 0-2 2.83V13a3 3 0 0 0 2 2.83V17a3.5 3.5 0 0 0 3.5 3.5"></path>
                <path d="M14.5 4.5A3.5 3.5 0 0 1 18 8v1a3 3 0 0 1 2 2.83V13a3 3 0 0 1-2 2.83V17a3.5 3.5 0 0 1-3.5 3.5"></path>
                <path d="M12 4v16"></path>
                <path d="M9 8.5c1 .2 2 .7 3 1.5"></path>
                <path d="M15 8.5c-1 .2-2 .7-3 1.5"></path>
                <path d="M8.5 14c1.2 0 2.4-.5 3.5-1.5"></path>
                <path d="M15.5 14c-1.2 0-2.4-.5-3.5-1.5"></path>
              </svg>
            </div>
          </div>

          <!-- Project information -->
          <div class="min-w-0">
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <h2 class="text-2xl font-bold sm:text-3xl">
                ThinkNeuro Neuroscience Research
              </h2>

              <span
                class="rounded-full bg-[#FFC72C] px-3 py-1 text-xs font-bold text-[#5c0000]"
              >
                RESEARCH
              </span>
            </div>

            <p class="mb-4 font-semibold text-[#990000]">
              May 2026 – August 2026 · Remote
            </p>

            <p class="text-base leading-relaxed opacity-80 sm:text-lg">
              A neuroscience research exploring wearable neurotechnology, scientific literature analysis, and computational research methods.(Still being conducted)
            </p>

            <!-- Tags -->
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Neuroscience
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                R
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Bibliometrix
              </span>

              <span class="rounded-full bg-[#990000]/10 px-3 py-1 text-sm">
                Data Visualization
              </span>
            </div>

            <a
              class="btn mt-6 w-full border-[#990000] bg-base-100 text-[#990000] hover:border-[#990000] hover:bg-[#990000] hover:text-white sm:w-auto"
              href="/cv"
            >
              View Research Experience →
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</BaseLayout>
---
const { sideBarActiveItemID } = Astro.props;

// Adds /personal-portfolio automatically on GitHub Pages,
// while still working correctly on localhost.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const menuItems = [
  {
    id: "home",
    label: "Home",
    href: `${base}/`,
  },
  {
    id: "projects",
    label: "Projects",
    href: `${base}/projects/`,
  },
  {
    id: "services",
    label: "Services",
    href: `${base}/services/`,
  },
  {
    id: "cv",
    label: "CV",
    href: `${base}/cv/`,
  },
];
---

<ul class="menu menu-md grow shrink gap-2 overflow-y-auto px-3 py-4">
  {
    menuItems.map((item) => (
      <li>
        <a
          id={item.id}
          href={item.href}
          aria-current={sideBarActiveItemID === item.id ? "page" : undefined}
          class:list={[
            "rounded-xl px-4 py-3 text-base font-semibold transition-all duration-200",
            sideBarActiveItemID === item.id
              ? "bg-[#990000] text-white shadow-md hover:bg-[#7a0000] hover:text-white"
              : "hover:bg-[#990000]/10 hover:text-[#990000]",
          ]}
        >
          {item.label}
        </a>
      </li>
    ))
  }
</ul>